@model ShopOnline.Models.Member
@using (Html.BeginForm("Edit", "CRUDmember", FormMethod.Post, new { @id = "form-1", @enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "form-message" })
    <div class="form-body">
        @Html.HiddenFor(model => model.dateCreate)
        @Html.HiddenFor(model => model.password)
        @Html.HiddenFor(model => model.memberId)
        <div class="row">
            <div class="col-md-8">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="firstName">FirstName</label>
                            @Html.EditorFor(model => model.firstName, new { htmlAttributes = new { @class = "form-control", @id = "firstName" } })
                            <span class="form-message"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="lastName">LastName</label>
                            @Html.EditorFor(model => model.lastName, new { htmlAttributes = new { @class = "form-control", @id = "lastName" } })
                            <span class="form-message"></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label for="email">Email</label>
                            @Html.EditorFor(model => model.email, new { htmlAttributes = new { @class = "form-control", @id = "email" } })
                            <span class="form-message"></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label for="phone">Phone</label>
                            @Html.EditorFor(model => model.phone, new { htmlAttributes = new { @class = "form-control", @id = "phone" } })
                            <span class="form-message"></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label for="birthday">Birthday</label>
                            @Html.TextBoxFor(model => model.birthday, new { @class = "form-control", @type = "date", @id = "birthday", @Value = Model.birthday.HasValue ? Model.birthday.Value.ToString("yyyy-MM-dd") : "" })
                            <span class="form-message"></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label for="address">Address</label>
                            @Html.EditorFor(model => model.address, new { htmlAttributes = new { @class = "form-control", @id = "address" } })
                            <span class="form-message"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label for="image">Image</label>
                    <div class="d-flex justify-content-center">
                        <img src=@Url.Content(Model.avatar) class="img-thumbnail" style="height: 157px; width: 157px; border-radius: 50%; object-fit: cover; margin-bottom: 10px" id="imagePreview" />
                    </div>
                    <input type="file" name="uploadFile" class="form-control-file" id="image" accept="image/jpeg, image/png" />
                    <span class="form-message"></span>
                </div>
                <div class="form-group">
                    <label for="productName">Role</label>
                    @Html.DropDownList("roleId", null, htmlAttributes: new { @class = "form-control" })
                    <span class="form-message"></span>
                </div>
                <div class="form-group">
                    <label for="status">Status</label>
                    @{
                        bool status = (Model.status.GetValueOrDefault(false) ? true : false);
                    }
                    @Html.CheckBoxFor(model => status, new { @class = "form-control" })
                </div>
            </div>
        </div>
    </div>
}
<script src="~/Content/js/validator.js"></script>
<script>
    Validator({
        form: '#form-1',
        formGroupSelector: '.form-group',
        errorSelector: '.form-message',
        rules: [
            Validator.isRequired('#firstName'),
            Validator.isRequired('#lastName'),
            Validator.isEmail('#email'),
            Validator.isRequired('#phone'),
            Validator.isDate('#birthday')
        ],
    });
</script>
<script>
    $("#image").on("change", function () {
        const file = this.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                $("#imagePreview").attr("src", e.target.result);
            }
            reader.readAsDataURL(file);
        }
    });
</script>

