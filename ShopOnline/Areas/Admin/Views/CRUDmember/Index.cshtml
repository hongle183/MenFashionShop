@using ShopOnline.Models
@model IEnumerable<Member>
@{
    ViewBag.Title = "Member";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutDashBoard.cshtml";
    var currentRole = Request.QueryString["role"];
}

<div class="page-breadcrumb">
    <div class="row">
        <div class="col-7 align-self-center">
            <h4 class="page-title text-truncate text-dark font-weight-medium mb-1">Member manage</h4>
            <div class="d-flex align-items-center">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb m-0 p-0">
                        <li class="breadcrumb-item"><a href="~/Admin/DashBoard/Index">Dash board</a></li>
                        <li class="breadcrumb-item active">Member list</li>
                    </ol>
                </nav>
            </div>
        </div>
        <div class="col-5 align-self-center">
            <div class="customize-input float-right">
                <select class="custom-select custom-select-set form-control bg-white border-0 custom-shadow custom-radius">
                    <option selected>Nov 25</option>
                    <option value="1">Oct 25</option>
                    <option value="2">Sep 25</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card-body">
    <h3 class="text-dark text-uppercase card-title">Member</h3>
    <div class="d-flex justify-content-between">
        <button id="btnAdd" class="btn btn-success">Add member</button>
        <ul class="nav nav-pills ">
            <li class="nav-item">
                <a class="nav-link @(string.IsNullOrEmpty(currentRole) ? "active" : "")" href="@Url.Action("Index", "CRUDmember")">All</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentRole == "Manager" ? "active" : "")" href="@Url.Action("Index", "CRUDmember", new { role = "Manager"})">Manager</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentRole == "Employee" ? "active" : "")" href="@Url.Action("Index", "CRUDmember", new { role = "Employee"})">Employee</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentRole == "Customer Member" ? "active" : "")" href="@Url.Action("Index", "CRUDmember", new { role = "Customer Member"})">Customer Member</a>
            </li>
        </ul>
    </div>

    <hr />
    <div class="table-responsive">
        <table class="table">
            <thead class="thead-light">
                <tr>
                    <th class="text-center">NO</th>
                    <th class="text-center">Account</th>
                    <th class="text-center">Name</th>
                    <th class="text-center">Birthday</th>
                    <th class="text-center">Phone</th>
                    <th class="text-center">Status</th>
                    <th class="text-center">Role</th>
                    <th class="text-center">Feature</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal" tabindex="-1" role="dialog" id="modal">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header" style="color:#6c757d;">
                <h4 class="modal-title">New member</h4>
            </div>
            <div class="modal-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-dark" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSubmit">Save changes</button>
            </div>
        </div>
    </div>
</div>

<script>
    var dataTable;

    $(document).ready(function () {
        dataTable = $('.table').DataTable($.extend(true, {}, defaultDataTableSettings, {
            ajax: {
                url: '@Url.Action("GetMember", "CRUDmember", new { role = ViewBag.role })',
                type: 'GET',
                dataSrc: 'listMember'
            },
            columns: [
                {
                    data: null, // auto numbering
                    className: 'text-center',
                    render: function (data, type, row, meta) {
                        return meta.row + 1; // Tạo số thứ tự (NO)
                    }
                },
                {
                    data: 'email',
                    className: 'text-start',
                    render: function (data, type, row) {
                        if (type === "sort" || type === "type") return data;

                        return `
                            <div class="row no-gutters align-items-center">
                                <div class="col-md-4">
                                    <img src="${row.avatar ? row.avatar : '/Content/img/avatar/avatar.png'}" alt="user" style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover;" />
                                </div>
                                <div class="col-md-8 text-left">
                                    ${data || ''}
                                </div>
                            </div>
                        `;
                    }
                },
                { data: 'name', className: 'text-center' },
                {
                    data: 'birthday',
                    className: 'text-center',
                    render: function (data, type) {
                        if (!data) return '';
                        // Format "/Date(1739750400000)/" (JSON .NET)
                        var ts = parseInt(data.replace(/\/Date\((\d+)\)\//, '$1'), 10);
                        // Khi DataTables yêu cầu sort/type -> trả numeric (timestamp)
                        if (type === 'sort' || type === 'type') return ts;

                        // Mặc định trả về display format
                        return moment(ts).format('DD/MM/YYYY');
                    }
                },
                { data: 'phone', className: 'text-center' },
                {
                    data: 'status',
                    className: 'text-center',
                    render: function (data, type) {
                        if (type === "sort" || type === "type") return data;

                        return (data === true || data === "true")
                            ? '<i class="fa fa-circle text-success font-12" data-toggle="tooltip" title="Checked"></i>'
                            : '<i class="fa fa-circle text-danger font-12" data-toggle="tooltip" title="Unchecked"></i>';
                    }
                },
                { data: 'role', className: 'text-center' },
                {
                    data: 'memberId',
                    className: 'text-center',
                    orderable: false,
                    render: function (id) {
                        return `
                        <button class="btn btn-warning edit-btn mr-2" name="update" data-id="${id}">Edit</button>
                    `;
                    }
                }
            ]
        }));
    });

    // Click button Add
    // Nút tĩnh (submit, open modal)
    $('#btnAdd').click(function (e) {
        e.preventDefault();

        $.ajax({
            url: '@Url.Action("Create", "CRUDmember")',
            type: 'get',
            dataType: 'html',
            success: function (res) {
                $('#modal .modal-body').html(res);
                $('#modal').modal();
            }
        });
    });

    // Click button Edit
    // Nút động (delete/edit trong bảng), được thêm vào DOM sau này (qua AJAX, DataTable, v.v.)
    $(document).on('click', "button[name='update']", function () {
        let idMember = $(this).data('id');
        $('.modal-title').html('Update member');
        $.ajax({
            url: '@Url.Action("Edit", "CRUDmember")',
            type: 'get',
            dataType: 'html',
            data: {
                id: idMember
            },
            success: function (res) {
                $('#modal .modal-body').html(res);
                $('#modal').modal();
            }
        });
    });

    // Submit form (Add/ Edit)
    // được thêm vào DOM sau này (qua AJAX, DataTable, v.v.)
    $(document).on('keydown', '#form-1', function (e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            handleSubmit();
        }
    });

    $('#btnSubmit').on('click', function () {
        handleSubmit();
    });

    function handleSubmit() {
        // ✅ Tạo FormData để gửi cả text và file
        var form = $("#form-1")[0]; // lấy phần tử DOM gốc, không phải đối tượng jQuery
        var formData = new FormData(form);

        $.ajax({
            url: $(form).attr("action"),
            type: $(form).attr("method"),
            dataType: "json",
            data: formData,
            processData: false, // ❗ không xử lý dữ liệu (để giữ nguyên dạng FormData)
            contentType: false, // ❗ để browser tự set Content-Type (multipart/form-data)
            success: function (res) {
                if (res.success) {
                    $("#modal").modal("hide");

                    dataTable.ajax.reload(null, false); // 🔄 reload mà không tải lại trang
                    // Tham số (null, false) => giữ nguyên trang hiện tại (không quay lại trang 1)

                    showToast({
                        type: "success",
                        message: res.msg,
                        language: "en"
                    });
                } else {
                    showToast({
                        type: "danger",
                        message: res.msg,
                        language: "en"
                    });
                }
            },
            error: function (err) {
                console.log(err.responseText);
            },
        });
    }
</script>
