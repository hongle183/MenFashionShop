@{
    ViewBag.Title = "Blog";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutDashBoard.cshtml";
}

<div class="page-breadcrumb">
    <div class="row">
        <div class="col-7 align-self-center">
            <h4 class="page-title text-truncate text-dark font-weight-medium mb-1">Blog manage</h4>
            <div class="d-flex align-items-center">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb m-0 p-0">
                        <li class="breadcrumb-item"><a href="~/Admin/CRUDproduct/Index">Dash board</a></li>
                        <li class="breadcrumb-item active">Blog list</li>
                    </ol>
                </nav>
            </div>
        </div>
        <div class="col-5 align-self-center">
            <div class="customize-input float-right">
                <select class="custom-select custom-select-set form-control bg-white border-0 custom-shadow custom-radius">
                    <option selected>Nov 25</option>
                    <option value="1">Oct 25</option>
                    <option value="2">Sep 25</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card-body">
    <h3 class="text-dark text-uppercase card-title">Blog</h3>
    <a href="@Url.Action("Create", "CRUDblog")" class="btn btn-success">Add blog</a>
    @if (TempData["msgCreate"] != null)
    {
        <script>
            showToast({
                type: "success",
                message: "@TempData["msgCreate"].ToString().Replace("\"", "\\\"")",
                language: "en"
            });
        </script>
    }
    @if (TempData["msgEdit"] != null)
    {
        <script>
            showToast({
                type: "success",
                message: "@TempData["msgEdit"].ToString().Replace("\"", "\\\"")",
                language: "en"
            });
        </script>
    }
    else if (TempData["msgEditFailed"] != null)
    {
        <script>
            showToast({
                type: "danger",
                message: "@TempData["msgEditFailed"].ToString().Replace("\"", "\\\"")",
                language: "en"
            });
        </script>
    }
    @if (TempData["msgDelete"] != null)
    {
        <script>
            showToast({
                type: "success",
                message: "@TempData["msgDelete"].ToString().Replace("\"", "\\\"")",
                language: "en"
            });
        </script>
    }
    else if (TempData["msgDeleteFailed"] != null)
    {
        <script>
            showToast({
                type: "danger",
                message: "@TempData["msgDeleteFailed"].ToString().Replace("\"", "\\\"")",
                language: "en"
            });
        </script>
    }

    <hr />
    <div class="table-responsive">
        <table class="table">
            <thead class="thead-light">
                <tr>
                    <th scope="col" class="text-center">NO</th>
                    <th class="text-center">Title</th>
                    <th class="text-center text-truncate">Date Update</th>
                    <th class="text-center">Author</th>
                    <th class="text-center">Public</th>
                    <th class="text-center">Feature</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
<script>
    var dataTable;

    $(document).ready(function () {
        dataTable = $('.table').DataTable($.extend(true, {}, defaultDataTableSettings, {
            ajax: {
                url: '@Url.Action("GetBlog", "CRUDblog")',
                type: 'GET',
                dataSrc: 'listBlog'
            },
            columns: [
                {
                    data: null, // auto numbering
                    className: 'text-center',
                    render: function (data, type, row, meta) {
                        return meta.row + 1; // Tạo số thứ tự (NO)
                    }
                },
                {
                    data: 'title',
                    className: 'text-start',
                    render: function (data, type, row) {
                        if (type === "sort" || type === "type") return data;

                        return `
                            <div class="row no-gutters align-items-center">
                                <div class="col-md-3">
                                    <img src="${row.image ? row.image : '/Content/img/Orders/empty_state.png'}" style="height:70px; max-height: fit-content; max-width: -webkit-fill-available; border-radius:8px;" />
                                </div>
                                <div class="col-md-9 text-left">
                                    ${data || ''}
                                </div>
                            </div>
                        `;
                    }
                },
                {
                    data: 'dateCreate',
                    className: 'text-center',
                    render: function (data, type) {
                        if (!data) return '';
                        // Format "/Date(1739750400000)/" (JSON .NET)
                        var ts = parseInt(data.replace(/\/Date\((\d+)\)\//, '$1'), 10);
                        // Khi DataTables yêu cầu sort/type -> trả numeric (timestamp)
                        if (type === 'sort' || type === 'type') return ts;

                        // Mặc định trả về display format
                        return moment(ts).format('DD/MM/YYYY');
                    }
                },
                { data: 'author', className: 'text-center' },
                {
                    data: 'status',
                    className: 'text-center',
                    render: function (data, type) {
                        if (type === "sort" || type === "type") return data;

                        return (data === true || data === "true")
                            ? '<i class="fa fa-circle text-success font-12" data-toggle="tooltip" title="Checked"></i>'
                            : '<i class="fa fa-circle text-danger font-12" data-toggle="tooltip" title="Unchecked"></i>';
                    }
                },
                {
                    data: 'articleId',
                    className: 'text-center',
                    orderable: false,
                    render: function (id) {
                        return `
                        <div class="d-flex justify-content-center">
                            <a href="@Url.Action("Edit", "CRUDblog")?id=${id}" class="btn btn-warning edit-btn mr-2">Edit</a>
                            <button class="btn btn-danger delete-btn" name="delete" data-id="${id}">Delete</button>
                        </div>
                    `;
                    }
                }
            ]
        }));
    });

    // Sự kiện click của button Delete
    $(document).on('click', "button[name='delete']", function () {
        let blogId = $(this).data('id');
        if (confirm("Are you sure you want to delete this?!")) {
            $.ajax({
                url: '@Url.Action("Delete", "CRUDblog")',
                type: 'post',
                dataType: 'json',
                data: {
                    id: blogId
                },
                success: function (res) {
                    if (res.success) {
                        dataTable.ajax.reload(null, false); // 🔄 reload mà không tải lại trang
                        // Tham số (null, false) => giữ nguyên trang hiện tại (không quay lại trang 1)

                        showToast({
                            type: "success",
                            message: res.msg,
                            language: "en"
                        });
                    } else {
                        showToast({
                            type: "danger",
                            message: res.msg,
                            language: "en"
                        });
                    }
                },
                error: function (err) {
                    console.log(err.responseText);
                },
            });
        }
    });
</script>
