@{
    ViewBag.Title = "Product";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutDashBoard.cshtml";
}
<div class="page-breadcrumb">
    <div class="row">
        <div class="col-7 align-self-center">
            <h4 class="page-title text-truncate text-dark font-weight-medium mb-1">Product manage</h4>
            <div class="d-flex align-items-center">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb m-0 p-0">
                        <li class="breadcrumb-item"><a href="~/Admin/DashBoard/Index">Dash board</a></li>
                        <li class="breadcrumb-item active">Product list</li>
                    </ol>
                </nav>
            </div>
        </div>
        <div class="col-5 align-self-center">
            <div class="customize-input float-right">
                <select class="custom-select custom-select-set form-control bg-white border-0 custom-shadow custom-radius">
                    <option selected>Nov 25</option>
                    <option value="1">Oct 25</option>
                    <option value="2">Sep 25</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card-body">
    <h3 class="text-dark text-uppercase card-title">Product</h3>
    <button id="btnAdd" class="btn btn-success">Add product</button>

    @if (TempData["msgEdit"] != null)
    {
        <script>
            showToast({
                type: "success",
                message: "@TempData["msgEdit"].ToString().Replace("\"", "\\\"")",
                language: "en"
            });
        </script>
    }
    else if (TempData["msgEditFailed"] != null)
    {
        <script>
            showToast({
                type: "danger",
                message: "@TempData["msgEditFailed"].ToString().Replace("\"", "\\\"")", 
                language: "en"
            });
        </script>
    }
   
    <hr />
    <div class="table-responsive">
        <table class="table display compact" style="width:100%">
            <thead class="thead-light">
                <tr>
                    <th class="text-center">NO</th>
                    <th class="text-center">Product name</th>
                    <th class="text-center">Price</th>
                    <th class="text-center">Discount</th>
                    <th class="text-center">Quantity</th>
                    <th class="text-center">Category</th>
                    <th class="text-center">Public</th>
                    <th class="text-center">Feature</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal" tabindex="-1" role="dialog" id="modal">
    <div class="modal-dialog modal-dialog-scrollable modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header" style="color:#6c757d;">
                <h4 class="modal-title">New product</h4>
            </div>
            <div class="modal-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-dark" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSubmit">Save changes</button>
            </div>
        </div>
    </div>
</div>

<script>
    var dataTable;

    $(document).ready(function () {
        dataTable = $('.table').DataTable($.extend(true, {}, defaultDataTableSettings, {
            ajax: {
                url: '@Url.Action("GetProduct", "CRUDproduct")',
                type: 'GET',
                dataSrc: 'listProduct'
            },
            columns: [
                {
                    data: null, // auto numbering
                    className: 'text-center',
                    render: function (data, type, row, meta) {
                        return meta.row + 1; // Tạo số thứ tự (NO)
                    }
                },
                {
                    data: 'productName',
                    className: 'text-start',
                    render: function (data, type, row) {
                        if (type === "sort" || type === "type") return data;

                        return `
                            <div class="row no-gutters align-items-center">
                                <div class="col-md-3">
                                    <img src="${row.image ? row.image : '/Content/img/Orders/empty_state.png'}" style="height:90px; max-height: fit-content; max-width: -webkit-fill-available; border-radius:8px;" />
                                </div>
                                <div class="col-md-9 text-left">
                                    ${data || ''}
                                </div>
                            </div>
                        `;
                    }
                },
                {
                    data: 'price',
                    className: 'text-center',
                    render: function (data) {
                        if (!data) return '0';
                        return parseFloat(data).toLocaleString('vi-VN'); // => 12.345.678
                    }
                },
                {
                    data: 'discount',
                    className: 'text-center',
                    render: function (discount) {
                        return `${discount}%`;
                    }
                },
                { data: 'quantity', className: 'text-center' },
                { data: 'category', className: 'text-center' },
                {
                    data: 'status',
                    className: 'text-center',
                    render: function (data, type) {
                        if (type === "sort" || type === "type") return data;

                        return (data === true || data === "true")
                            ? '<i class="fa fa-circle text-success font-12" data-toggle="tooltip" title="Checked"></i>'
                            : '<i class="fa fa-circle text-danger font-12" data-toggle="tooltip" title="Unchecked"></i>';
                    }
                },
                {
                    data: 'productId',
                    className: 'text-center',
                    orderable: false,
                    render: function (id) {
                        return `
                        <div class="d-flex justify-content-center">
                            <a href="@Url.Action("Edit", "CRUDproduct")?id=${id}" class="btn btn-warning edit-btn mr-2">Edit</a>
                            <button class="btn btn-danger delete-btn" name="delete" data-id="${id}">Delete</button>
                        </div>
                    `;
                    }
                }
            ]
        }));
    });

    // Click button Add
    // Nút tĩnh (submit, open modal)
    $('#btnAdd').click(function (e) {
        e.preventDefault();

        $.ajax({
            url: '@Url.Action("Create", "CRUDproduct")',
            type: 'get',
            dataType: 'html',
            success: function (res) {
                $('#modal .modal-body').html(res);
                $('#modal').modal();

                initTinyMCE();
            }
        });
    });

    // Submit form (Add)
    // được thêm vào DOM sau này (qua AJAX, DataTable, v.v.)
    $(document).on('keydown', '#form-1', function (e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            handleSubmit();
        }
    });

    $('#btnSubmit').on('click', function () {
        handleSubmit();
    });

    // Sự kiện click của button Delete
    $(document).on('click', "button[name='delete']", function () {
        let productId = $(this).data('id');
        if (confirm("Are you sure you want to delete this?!")) {
            $.ajax({
                url: '@Url.Action("Delete", "CRUDproduct")',
                type: 'post',
                dataType: 'json',
                data: {
                    id: productId
                },
                success: function (res) {
                    if (res.success) {
                        dataTable.ajax.reload(null, false); // 🔄 reload mà không tải lại trang
                        // Tham số (null, false) => giữ nguyên trang hiện tại (không quay lại trang 1)

                        showToast({
                            type: "success",
                            message: res.msg,
                            language: "en"
                        });
                    } else {
                        showToast({
                            type: "danger",
                            message: res.msg,
                            language: "en"
                        });
                    }
                },
                error: function (err) {
                    console.log(err.responseText);
                },
            });
        }
    });

    function handleSubmit() {
        // ⚠️ Bắt buộc đồng bộ nội dung TinyMCE về textarea
        if (typeof tinymce !== "undefined") {
            tinymce.triggerSave();
        }

        // ✅ Tạo FormData để gửi cả text và file
        var form = $("#form-1")[0]; // lấy phần tử DOM gốc, không phải đối tượng jQuery
        var formData = new FormData(form);

        $.ajax({
            url: $(form).attr("action"),
            type: $(form).attr("method"),
            dataType: "json",
            data: formData,
            processData: false, // ❗ không xử lý dữ liệu (để giữ nguyên dạng FormData)
            contentType: false, // ❗ để browser tự set Content-Type (multipart/form-data)
            success: function (res) {
                if (res.success) {
                    $("#modal").modal("hide");

                    dataTable.ajax.reload(null, false); // 🔄 reload mà không tải lại trang
                    // Tham số (null, false) => giữ nguyên trang hiện tại (không quay lại trang 1)

                    showToast({
                        type: "success",
                        message: res.msg,
                        language: "en"
                    });
                } else {
                    showToast({
                        type: "danger",
                        message: res.msg,
                        language: "en"
                    });
                }
            },
            error: function (err) {
                console.log(err.responseText);
            },
        });
    }
</script>
