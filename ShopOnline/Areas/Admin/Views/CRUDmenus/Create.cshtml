@model ShopOnline.Models.Menu

@using (Html.BeginForm("Create", "CRUDmenus", FormMethod.Post, new { @id = "form-1" }))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "form-message" })

    <div class="form-body">
        <div class="row">
            <div class="col-md-12">
                <div class="form-group">
                    <label for="menuName">Menu name</label>
                    <input type="text" class="form-control" name="name" id="menuName" />
                    <span class="form-message"></span>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-8">
                <div class="form-group">
                    <label for="meta">Meta</label>
                    <input type="text" class="form-control" name="meta" id="meta" />
                    <span class="form-message"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label for="order">Order</label>
                    @*<input type="number" class="form-control" name="order" id="order" value="@ViewBag.count" />*@
                    @Html.DropDownListFor(model => model.order,
                         (SelectList)ViewBag.AvailableOrders,
                         new { @class = "form-control" })
                    <span class="form-message"></span>
                </div>
            </div>
        </div>
    </div>
}
<script src="~/Content/js/validator.js"></script>
<script src="~/Areas/Admin/Content/js/helper.js"></script>
<script>
    Validator({
        form: '#form-1',
        formGroupSelector: '.form-group',
        errorSelector: '.form-message',
        rules: [
            Validator.isRequired('#menuName'),
            Validator.isRequired('#meta'),
            //Validator.isRequired('#order')
        ],
    });

    $(document).on('input', '#menuName', function () {
        const menuName = $(this);
        const meta = $('#meta');

        if (meta.length) {
            meta.val(cleanText(menuName.val()));

            // Kích hoạt lại sự kiện input để Validator bắt được thay đổi
            meta.trigger('input');
        }
    });
</script>
