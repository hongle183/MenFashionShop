@{
    ViewBag.Title = "Menu";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutDashBoard.cshtml";
}

<div class="page-breadcrumb">
    <div class="row">
        <div class="col-7 align-self-center">
            <h4 class="page-title text-truncate text-dark font-weight-medium mb-1">Menu manage</h4>
            <div class="d-flex align-items-center">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb m-0 p-0">
                        <li class="breadcrumb-item"><a href="~/Admin/DashBoard/Index">Dash board</a></li>
                        <li class="breadcrumb-item active">Menu list</li>
                    </ol>
                </nav>
            </div>
        </div>
        <div class="col-5 align-self-center">
            <div class="customize-input float-right">
                <select class="custom-select custom-select-set form-control bg-white border-0 custom-shadow custom-radius">
                    <option selected>Nov 25</option>
                    <option value="1">Oct 25</option>
                    <option value="2">Sep 25</option>
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card-body">
    <h3 class="text-dark text-uppercase card-title">Menu</h3>
    <button id="btnAdd" class="btn btn-success">Add menu</button>
    <hr />

    <div class="table-responsive">
        <table class="table">
            <thead class="thead-light">
                <tr>
                    <th scope="col" class="text-center">NO</th>
                    <th class="text-center">Name</th>
                    <th class="text-center">Meta</th>
                    <th class="text-center">Public</th>
                    <th class="text-center">Order</th>
                    <th class="text-center">Date Update</th>
                    <th class="text-center">Feature</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal" tabindex="-1" role="dialog" id="modal">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header" style="color:#6c757d;">
                <h4 class="modal-title">New menu</h4>
            </div>
            <div class="modal-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-dark" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSubmit">Save changes</button>
            </div>
        </div>
    </div>
</div>
<script>
    var dataTable;

    $(document).ready(function () {
        dataTable = $('.table').DataTable($.extend(true, {}, defaultDataTableSettings, {
            ajax: {
                url: '@Url.Action("GetMenu", "CRUDmenus")',
                type: 'GET',
                dataSrc: 'listMenu'
            },
            columns: [
                {
                    data: null, // auto numbering
                    className: 'text-center',
                    render: function (data, type, row, meta) {
                        return meta.row + 1; // Tạo số thứ tự (NO)
                    }
                },
                { data: 'name', className: 'text-center' },
                { data: 'meta', className: 'text-center' },
                {
                    data: 'status',
                    className: 'text-center',
                    render: function (data, type) {
                        if (type === "sort" || type === "type") return data;

                        return (data === true || data === "true")
                            ? '<i class="fa fa-circle text-success font-12" data-toggle="tooltip" title="Checked"></i>'
                            : '<i class="fa fa-circle text-danger font-12" data-toggle="tooltip" title="Unchecked"></i>';
                    }
                },
                { data: 'order', className: 'text-center' },
                {
                    data: 'dateCreate',
                    className: 'text-center',
                    render: function (data, type) {
                        if (!data) return '';
                        // Format "/Date(1739750400000)/" (JSON .NET)
                        var ts = parseInt(data.replace(/\/Date\((\d+)\)\//, '$1'), 10);
                        // Khi DataTables yêu cầu sort/type -> trả numeric (timestamp)
                        if (type === 'sort' || type === 'type') return ts;

                        // Mặc định trả về display format
                        return moment(ts).format('DD/MM/YYYY');
                    }
                },
                {
                    data: 'menuId',
                    className: 'text-center',
                    orderable: false,
                    render: function (id) {
                        return `
                        <div class="d-flex justify-content-center">
                            <button class="btn btn-warning edit-btn mr-2" name="update" data-id="${id}">Edit</button>
                            <button class="btn btn-danger delete-btn" name="delete" data-id="${id}">Delete</button>
                        </div>
                    `;
                    }
                }
            ]
        }));
    });

    // Click button Add
    // Nút tĩnh (submit, open modal)
    $('#btnAdd').click(function (e) {
        e.preventDefault();

        $('.modal-title').html('New menu');
        $.ajax({
            url: '@Url.Action("Create", "CRUDmenus")',
            type: 'get',
            dataType: 'html',
            success: function (res) {
                $('#modal .modal-body').html(res);
                $('#modal').modal();
            }
        });
    });

    // Click button Edit
    // Nút động (delete/edit trong bảng), được thêm vào DOM sau này (qua AJAX, DataTable, v.v.)
    $(document).on('click', "button[name='update']", function () {
        let idMenu = $(this).data('id');
        $('.modal-title').html('Update menu');
        $.ajax({
            url: '@Url.Action("Edit", "CRUDmenus")',
            type: 'get',
            dataType: 'html',
            data: {
                id: idMenu
            },
            success: function (res) {
                $('#modal .modal-body').html(res);
                $('#modal').modal();
            }
        });
    });

    // Submit form (Add & Edit)
    // được thêm vào DOM sau này (qua AJAX, DataTable, v.v.)
    $(document).on('keydown', '#form-1', function (e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            handleSubmit();
        }
    });

    $('#btnSubmit').on('click', function () {
        handleSubmit();
    });

    // Sự kiện click của button Delete
    $(document).on('click', "button[name='delete']", function () {
        let idMenu = $(this).data('id');
        if (confirm("Are you sure you want to delete this?!")) {
            $.ajax({
                url: '@Url.Action("Delete", "CRUDmenus")',
                type: 'post',
                dataType: 'json',
                data: {
                    id: idMenu
                },
                success: function (res) {
                    if (res.success) {
                        dataTable.ajax.reload(null, false); // 🔄 reload mà không tải lại trang
                        // Tham số (null, false) => giữ nguyên trang hiện tại (không quay lại trang 1)

                        showToast({
                            type: "success",
                            message: res.msg,
                            language: "en"
                        });
                    } else {
                        showToast({
                            type: "danger",
                            message: res.msg,
                            language: "en"
                        });
                    }
                },
                error: function (err) {
                    console.log(err.responseText);
                },
            });
        }
    });

    function handleSubmit() {
        var form = $("#form-1");

        $.ajax({
            url: form.attr("action"),
            type: form.attr("method"),
            dataType: "json",
            data: form.serialize(),
            success: function (res) {
                if (res.success) {
                    $("#modal").modal("hide");

                    dataTable.ajax.reload(null, false); // 🔄 reload mà không tải lại trang
                    // Tham số (null, false) => giữ nguyên trang hiện tại (không quay lại trang 1)

                    showToast({
                        type: "success",
                        message: res.msg,
                        language: "en"
                    });
                } else {
                    showToast({
                        type: "danger",
                        message: res.msg,
                        language: "en"
                    });
                }
            },
            error: function (err) {
                console.log(err.responseText);
            },
        });
    }
</script>
